// =============================================================================
// Ummah — Prisma Schema
// Maps 1-to-1 with the approved ER diagram from the Systems Architect.
//
// Conventions:
//   - All PKs are UUIDs generated by the DB (gen_random_uuid()).
//   - Soft-deletes on User via deletedAt.
//   - GeoQueryLog retains geohash prefix only — raw GPS never touches this schema.
//   - PrayerTiming.verifiedBy is a nullable self-referential FK to User.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  member
  admin
  verifier
}

enum Madhab {
  Hanafi
  Shafii   // stored as "Shafi'i" in display layer
  Maliki
  Hanbali
}

enum MosqueStatus {
  active
  closed
  unverified
}

enum CalcMethod {
  manual
  MWL
  ISNA
  Egypt
}

enum VerificationStatus {
  pending
  verified
  rejected
}

enum PrayerSlot {
  fajr
  dhuhr
  asr
  maghrib
  isha
  jumuah
}

// ---------------------------------------------------------------------------
// User
// Stores only durable identity data. No GPS coordinates ever persisted here.
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayName  String    @map("display_name") @db.VarChar(120)
  emailHash    String    @unique @map("email_hash") @db.Char(64)  // SHA-256 hex, not raw email
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         UserRole  @default(member)
  locale       String    @default("en") @db.VarChar(10)           // e.g. "en-IN", "ar-SA"
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")                        // soft-delete

  // Relations
  geoQueryLogs   GeoQueryLog[]
  checkIns       CheckIn[]
  registeredMosques Mosque[]   @relation("MosqueAddedBy")
  verifiedTimings   PrayerTiming[] @relation("PrayerTimingVerifiedBy")

  @@index([deletedAt])
  @@map("users")
}

// ---------------------------------------------------------------------------
// GeoQueryLog
// Data minimization: stores a truncated geohash (~1 km cell), never raw coords.
// Purged after 30 days via a scheduled job (pg_cron or external worker).
// ---------------------------------------------------------------------------

model GeoQueryLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  geohashPrefix String   @map("geohash_prefix") @db.VarChar(8)   // precision-4 ≈ 40 km cell
  radiusKm      Float    @map("radius_km")
  resultCount   Int      @map("result_count")
  queriedAt     DateTime @default(now()) @map("queried_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([queriedAt])  // used by the 30-day purge job: DELETE WHERE queried_at < NOW() - INTERVAL '30 days'
  @@map("geo_query_logs")
}

// ---------------------------------------------------------------------------
// Mosque
// Canonical record. Coordinates are operator-supplied public data.
// Mirrored to Redis GEO on create/update for spatial queries.
// ---------------------------------------------------------------------------

model Mosque {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @db.VarChar(255)
  nameAr      String?      @map("name_ar") @db.VarChar(255)
  latitude    Float                                               // WGS-84
  longitude   Float                                              // WGS-84
  addressLine String?      @map("address_line") @db.VarChar(500)
  city        String       @db.VarChar(120)
  countryCode String       @map("country_code") @db.Char(2)     // ISO 3166-1 alpha-2
  madhab      Madhab
  status      MosqueStatus @default(unverified)
  addedBy     String       @map("added_by") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  addedByUser    User           @relation("MosqueAddedBy", fields: [addedBy], references: [id])
  prayerTimings  PrayerTiming[]
  checkIns       CheckIn[]

  @@index([status])
  @@index([countryCode, city])
  @@index([latitude, longitude])
  @@map("mosques")
}

// ---------------------------------------------------------------------------
// PrayerTiming
// Always linked to a specific Mosque. Carries a full verifier chain.
// Times stored as String (HH:MM) for timezone-agnostic portability.
// ---------------------------------------------------------------------------

model PrayerTiming {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mosqueId           String             @map("mosque_id") @db.Uuid
  effectiveDate      DateTime           @map("effective_date") @db.Date
  fajr               String             @db.VarChar(5)           // "HH:MM"
  sunrise            String             @db.VarChar(5)
  dhuhr              String             @db.VarChar(5)
  asr                String             @db.VarChar(5)
  maghrib            String             @db.VarChar(5)
  isha               String             @db.VarChar(5)
  jumuah             String?            @db.VarChar(5)           // nullable; Friday only
  calcMethod         CalcMethod         @default(manual) @map("calc_method")
  verificationStatus VerificationStatus @default(pending) @map("verification_status")
  verifiedBy         String?            @map("verified_by") @db.Uuid
  verifiedAt         DateTime?          @map("verified_at")
  sourceNote         String?            @map("source_note") @db.VarChar(1000)
  createdAt          DateTime           @default(now()) @map("created_at")

  // Relations
  mosque       Mosque  @relation(fields: [mosqueId], references: [id], onDelete: Cascade)
  verifiedByUser User? @relation("PrayerTimingVerifiedBy", fields: [verifiedBy], references: [id], onDelete: SetNull)

  @@unique([mosqueId, effectiveDate])  // one record per mosque per day
  @@index([mosqueId, effectiveDate])
  @@index([verificationStatus])
  @@map("prayer_timings")
}

// ---------------------------------------------------------------------------
// CheckIn
// Social layer. Ephemeral by design — users can delete their own records.
// isAnonymous suppresses displayName in API responses (enforced in controller).
// ---------------------------------------------------------------------------

model CheckIn {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  mosqueId     String     @map("mosque_id") @db.Uuid
  prayerSlot   PrayerSlot @map("prayer_slot")
  checkedInAt  DateTime   @default(now()) @map("checked_in_at")
  isAnonymous  Boolean    @default(false) @map("is_anonymous")
  note         String?    @db.VarChar(280)

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mosque Mosque @relation(fields: [mosqueId], references: [id], onDelete: Cascade)

  @@index([mosqueId, checkedInAt])
  @@index([userId, checkedInAt])
  @@map("check_ins")
}
